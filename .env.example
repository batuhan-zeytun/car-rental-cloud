APP_NAME=Car Rental Cloud
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=change-me-in-production
PORT=8000

# Local default works without this. Use PostgreSQL in Docker/cloud.
DATABASE_URL=postgresql://car_rental:car_rental@db:5432/car_rental
REDIS_URL=redis://redis:6379/0

AUTO_CREATE_DB=true
SEED_SAMPLE_DATA=true
CACHE_TTL_SECONDS=30
LOG_LEVEL=INFO
